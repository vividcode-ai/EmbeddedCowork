{
  "name": "@embeddedcowork/tauri-app",
  "version": "0.0.21",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "node ./scripts/dev-init.js && npm run prebuild && tauri dev",
    "dev:ui": "npm run dev --workspace @embeddedcowork/ui",
    "dev:prep": "node ./scripts/dev-prep.js",
    "dev:bootstrap": "npm run prebuild && npm run dev:ui",
    "sync:version": "node ./scripts/sync-tauri-version.js",
    "prebuild": "node ./scripts/prebuild.js",
    "bundle:server": "npm run prebuild",
    "build": "tauri build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1"
  }
}
