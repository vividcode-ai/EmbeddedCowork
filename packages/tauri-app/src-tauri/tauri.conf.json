{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EmbeddedCowork",
  "version": "0.0.12",
  "identifier": "ai.vividcode.embeddedcowork.client",
  "build": {
    "beforeDevCommand": "npm run dev:bootstrap",
    "beforeBuildCommand": "npm run bundle:server",
    "frontendDist": "resources/ui-loading"
  },
  "app": {
    "enableGTKAppId": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "EmbeddedCowork",
        "url": "loading.html",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "theme": "Dark",
        "backgroundColor": "#1a1a1a",
        "zoomHotkeysEnabled": true
      }
    ],
    "security": {
      "assetProtocol": {
        "scope": [
          "**"
        ]
      },
      "capabilities": [
        "main-window-native-dialogs"
      ]
    }
  },
  "bundle": {
    "active": true,
    "linux": {
      "deb": {
        "files": {
          "/usr/share/applications/ai.vividcode.embeddedcowork.client.desktop": "icons/linux/ai.vividcode.embeddedcowork.client.desktop",
          "/usr/share/icons/hicolor/32x32/apps/embeddedcowork-tauri.png": "icons/linux/32x32.png",
          "/usr/share/icons/hicolor/48x48/apps/embeddedcowork-tauri.png": "icons/linux/48x48.png",
          "/usr/share/icons/hicolor/64x64/apps/embeddedcowork-tauri.png": "icons/linux/64x64.png",
          "/usr/share/icons/hicolor/128x128/apps/embeddedcowork-tauri.png": "icons/linux/128x128.png",
          "/usr/share/icons/hicolor/256x256/apps/embeddedcowork-tauri.png": "icons/linux/256x256.png",
          "/usr/share/icons/hicolor/512x512/apps/embeddedcowork-tauri.png": "icons/linux/512x512.png"
        }
      },
      "rpm": {
        "files": {
          "/usr/share/applications/ai.vividcode.embeddedcowork.client.desktop": "icons/linux/ai.vividcode.embeddedcowork.client.desktop",
          "/usr/share/icons/hicolor/32x32/apps/embeddedcowork-tauri.png": "icons/linux/32x32.png",
          "/usr/share/icons/hicolor/48x48/apps/embeddedcowork-tauri.png": "icons/linux/48x48.png",
          "/usr/share/icons/hicolor/64x64/apps/embeddedcowork-tauri.png": "icons/linux/64x64.png",
          "/usr/share/icons/hicolor/128x128/apps/embeddedcowork-tauri.png": "icons/linux/128x128.png",
          "/usr/share/icons/hicolor/256x256/apps/embeddedcowork-tauri.png": "icons/linux/256x256.png",
          "/usr/share/icons/hicolor/512x512/apps/embeddedcowork-tauri.png": "icons/linux/512x512.png"
        }
      }
    },
    "resources": [
      "resources/server",
      "resources/ui-loading"
    ],
    "icon": [
      "icon.icns",
      "icon.ico",
      "icon.png"
    ],
    "targets": [
      "app",
      "appimage",
      "deb",
      "rpm",
      "nsis"
    ]
  }
}
