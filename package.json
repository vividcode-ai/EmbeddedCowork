{
  "name": "Embedded-Cowork",
  "version": "0.0.13",
  "private": true,
  "description": "EmbeddedCowork monorepo workspace",
  "license": "MIT",
  "workspaces": {
    "packages": [
      "packages/server",
      "packages/server/publish-packages/*",
      "packages/ui",
      "packages/electron-app",
      "packages/tauri-app"
    ]
  },
  "scripts": {
    "dev": "npm run dev --workspace @vividcodeAI/embeddedcowork-electron-app",
    "dev:electron": "npm run dev --workspace @vividcodeAI/embeddedcowork-electron-app",
    "dev:tauri": "npm run dev --workspace @embeddedcowork/tauri-app",
    "build": "npm run build --workspace @vividcodeAI/embeddedcowork-electron-app",
    "build:tauri": "npm run build --workspace @embeddedcowork/tauri-app",
    "build:ui": "npm run build --workspace @embeddedcowork/ui",
    "build:mac-x64": "npm run build:mac-x64 --workspace @vividcodeAI/embeddedcowork-electron-app",
    "build:binaries": "npm run build:binaries --workspace @vividcodeAI/embeddedcowork-electron-app",
    "typecheck": "npm run typecheck --workspace @embeddedcowork/ui && npm run typecheck --workspace @vividcodeAI/embeddedcowork-electron-app",
    "bumpVersion": "node ./scripts/bump-version.js"
  },
  "dependencies": {
    "7zip-bin": "^5.2.0",
    "google-auth-library": "^10.5.0"
  },
  "devDependencies": {
    "baseline-browser-mapping": "^2.9.11"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "4.52.5",
    "@rollup/rollup-darwin-x64": "4.52.5",
    "@rollup/rollup-linux-arm64-gnu": "4.52.5",
    "@rollup/rollup-linux-x64-gnu": "4.52.5",
    "@rollup/rollup-win32-arm64-msvc": "4.52.5",
    "@rollup/rollup-win32-x64-msvc": "4.52.5"
  }
}
